{
	"layer": "top",
	"position": "top",
    "height": 45,
	"margin-top": 0,
	"margin-left": 0,
	"margin-right": 0,
	"modules-left": [
		"custom/icon",
		"hyprland/workspaces",
        "custom/weather"
	],
	"modules-center": [
		"temperature",
		"cpu",
		"memory"
	],
	"modules-right": [ 
		"tray",
		"battery",
		"backlight",
		"wireplumber",
        "bluetooth",
		"network",
		"custom/power",
        "clock"
	],
	"include": [
		"~/.config/waybar/modules.jsonc"
	]
}
